module p21@npinto21/p21-sqlite@v1

repository github npinto21/p21-sqlite
exports p21.npinto21.sqlite

native dep sqlite3 required

native registry native/module_native_sqlite_registry.c
native runtime native/module_native_sqlite_runtime.c
bridge c native/sqlite_bridge.c

build include native
build source native/module_native_sqlite_registry.c
build source native/module_native_sqlite_runtime.c
build source native/sqlite_bridge.c
build link sqlite3
